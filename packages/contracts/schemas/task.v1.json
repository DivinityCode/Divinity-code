{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task",
  "type": "object",
  "required": ["task_id", "objective", "repo", "scope", "policy_id", "budget", "created_at"],
  "properties": {
    "task_id": { "type": "string" },
    "objective": { "type": "string" },
    "repo": { "type": "string" },
    "scope": {
      "type": "object",
      "required": ["org_id", "project_id"],
      "properties": {
        "org_id": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "policy_id": { "type": "string" },
    "budget": {
      "type": "object",
      "required": ["soft_limit_usd", "hard_limit_usd"],
      "properties": {
        "soft_limit_usd": { "type": "number", "minimum": 0 },
        "hard_limit_usd": { "type": "number", "minimum": 0 }
      }
    },
    "success_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "connector_references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["adapter", "resource_type", "resource_id"],
        "properties": {
          "adapter": {
            "type": "string",
            "enum": ["ticket_reference", "docs_reference", "ci_status"]
          },
          "resource_type": {
            "type": "string",
            "enum": ["ticket", "issue", "document", "knowledge_base", "ci_run", "check_run", "deployment"]
          },
          "resource_id": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "metadata": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "llm_provider": {
      "type": "object",
      "required": ["provider_id"],
      "properties": {
        "provider_id": {
          "type": "string",
          "enum": ["openrouter", "anthropic", "openai_api", "google_gemini", "groq", "cerebras", "mistral", "github_models", "custom_openai_compatible"]
        },
        "model": { "type": "string" },
        "base_url": { "type": "string" }
      },
      "additionalProperties": false
    },
    "toolsets": {
      "type": "object",
      "required": ["enabled", "disabled"],
      "properties": {
        "enabled": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["web", "file", "terminal", "code_execution", "browser", "memory", "delegation", "connectors", "approvals"]
          }
        },
        "disabled": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["web", "file", "terminal", "code_execution", "browser", "memory", "delegation", "connectors", "approvals"]
          }
        }
      },
      "additionalProperties": false
    },
    "provider_runtime": {
      "type": "object",
      "required": ["format", "provider_id", "display_name", "transport", "base_url", "model", "auth", "capabilities", "source"],
      "properties": {
        "format": { "const": "divinity.provider_runtime.v1" },
        "provider_id": {
          "type": "string",
          "enum": ["openrouter", "anthropic", "openai_api", "google_gemini", "groq", "cerebras", "mistral", "github_models", "custom_openai_compatible"]
        },
        "display_name": { "type": "string", "minLength": 1 },
        "transport": {
          "type": "string",
          "enum": ["chat_completions", "anthropic_messages", "codex_responses"]
        },
        "base_url": { "type": "string" },
        "model": { "type": "string" },
        "auth": {
          "type": "object",
          "required": ["mode", "credential_required", "credential_configured", "credential_env_vars", "configured_env_vars"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["api_key", "oauth_token", "none"]
            },
            "credential_required": { "type": "boolean" },
            "credential_configured": { "type": "boolean" },
            "credential_env_vars": {
              "type": "array",
              "items": { "type": "string" }
            },
            "configured_env_vars": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source": { "type": "string" }
      },
      "additionalProperties": false
    },
    "toolset_resolution": {
      "type": "object",
      "required": ["format", "toolsets", "tools"],
      "properties": {
        "format": { "const": "divinity.toolset_resolution.v1" },
        "toolsets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["format", "toolset_id", "description", "tools", "default_enabled", "risk_level", "policy_permissions"],
            "properties": {
              "format": { "const": "divinity.toolset.v1" },
              "toolset_id": {
                "type": "string",
                "enum": ["web", "file", "terminal", "code_execution", "browser", "memory", "delegation", "connectors", "approvals"]
              },
              "description": { "type": "string", "minLength": 1 },
              "tools": {
                "type": "array",
                "items": { "type": "string" }
              },
              "default_enabled": { "type": "boolean" },
              "risk_level": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "policy_permissions": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        },
        "tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "policy_permissions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risk_summary": {
          "type": "object",
          "required": ["highest_risk_level", "high_risk_toolsets", "medium_risk_toolsets", "low_risk_toolsets"],
          "properties": {
            "highest_risk_level": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "high_risk_toolsets": {
              "type": "array",
              "items": { "type": "string" }
            },
            "medium_risk_toolsets": {
              "type": "array",
              "items": { "type": "string" }
            },
            "low_risk_toolsets": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "provider_capability_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["provider_id", "capability", "status", "required_by_toolsets"],
            "properties": {
              "provider_id": { "type": "string" },
              "capability": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["supported", "missing"]
              },
              "required_by_toolsets": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        },
        "operator_controls": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["control_id", "status", "reason", "toolsets"],
            "properties": {
              "control_id": {
                "type": "string",
                "enum": ["approval_required", "provider_capability_review"]
              },
              "status": {
                "type": "string",
                "enum": ["recommended", "required"]
              },
              "reason": { "type": "string" },
              "provider_id": { "type": "string" },
              "capability": { "type": "string" },
              "toolsets": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
