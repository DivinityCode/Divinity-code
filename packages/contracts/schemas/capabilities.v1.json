{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapabilitiesCatalog",
  "type": "object",
  "required": ["format", "generated_at", "policies", "execution_adapters", "runtime_adapters", "llm_providers", "provider_secret_store_backends", "toolsets", "runner_isolation_profiles", "connector_adapters", "starter_recipes"],
  "properties": {
    "format": { "const": "divinity.capabilities.v1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["policy_id", "permissions", "approval_threshold"],
        "properties": {
          "policy_id": { "type": "string" },
          "permissions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "approval_threshold": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          }
        },
        "additionalProperties": false
      }
    },
    "execution_adapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["adapter", "description", "action_types", "shell_interpolation"],
        "properties": {
          "adapter": {
            "type": "string",
            "enum": ["file_read", "git_status", "node_test", "package_script", "manual"]
          },
          "description": { "type": "string", "minLength": 1 },
          "action_types": {
            "type": "array",
            "items": { "type": "string" }
          },
          "shell_interpolation": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "runtime_adapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["adapter", "kind", "description", "command", "capabilities", "requires_auth", "default_isolation_profile"],
        "properties": {
          "adapter": {
            "type": "string",
            "enum": ["divinity_local", "claude_local", "codex_local", "generic_process"]
          },
          "kind": {
            "type": "string",
            "enum": ["local", "external"]
          },
          "description": { "type": "string", "minLength": 1 },
          "command": {
            "type": ["string", "null"]
          },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "requires_auth": { "type": "boolean" },
          "default_isolation_profile": {
            "type": "string",
            "enum": ["workspace_snapshot", "container_sandbox"]
          }
        },
        "additionalProperties": false
      }
    },
    "llm_providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["format", "provider_id", "display_name", "transport", "base_url", "auth_modes", "credential_env_vars", "supports_custom_base_url", "default_model", "capabilities", "source"],
        "properties": {
          "format": { "const": "divinity.llm_provider.v1" },
          "provider_id": {
            "type": "string",
            "enum": ["openrouter", "anthropic", "openai_api", "google_gemini", "groq", "cerebras", "mistral", "github_models", "custom_openai_compatible"]
          },
          "display_name": { "type": "string", "minLength": 1 },
          "transport": {
            "type": "string",
            "enum": ["chat_completions", "anthropic_messages", "codex_responses"]
          },
          "base_url": { "type": "string" },
          "auth_modes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["api_key", "oauth_token", "none"]
            }
          },
          "credential_env_vars": {
            "type": "array",
            "items": { "type": "string" }
          },
          "supports_custom_base_url": { "type": "boolean" },
          "default_model": { "type": "string" },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "source": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "provider_secret_store_backends": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["format", "backend_id", "backend_kind", "display_name", "description", "production_ready", "broker_command_required", "configuration_env_vars", "redacts_secret_values", "redacts_deployment_secret_ids", "test_only"],
        "properties": {
          "format": { "const": "divinity.provider_secret_store_backend.v1" },
          "backend_id": {
            "type": "string",
            "enum": ["local_file", "external_command", "aws_secrets_manager", "gcp_secret_manager", "azure_key_vault", "hashicorp_vault", "hosted_memory"]
          },
          "backend_kind": {
            "type": "string",
            "enum": ["local_file", "managed_command", "managed_secret_store", "hosted_operator"]
          },
          "display_name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "production_ready": { "type": "boolean" },
          "broker_command_required": { "type": "boolean" },
          "configuration_env_vars": {
            "type": "array",
            "items": { "type": "string" }
          },
          "redacts_secret_values": { "type": "boolean" },
          "redacts_deployment_secret_ids": { "type": "boolean" },
          "test_only": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "toolsets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["format", "toolset_id", "description", "tools", "default_enabled", "risk_level", "policy_permissions"],
        "properties": {
          "format": { "const": "divinity.toolset.v1" },
          "toolset_id": {
            "type": "string",
            "enum": ["web", "file", "terminal", "code_execution", "browser", "memory", "delegation", "connectors", "approvals"]
          },
          "description": { "type": "string", "minLength": 1 },
          "tools": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "default_enabled": { "type": "boolean" },
          "risk_level": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "policy_permissions": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "runner_isolation_profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["profile_id", "kind", "description", "requires_runtime", "runtime", "image", "network", "workspace_mount", "shell_interpolation"],
        "properties": {
          "profile_id": {
            "type": "string",
            "enum": ["workspace_snapshot", "container_sandbox"]
          },
          "kind": {
            "type": "string",
            "enum": ["workspace", "container"]
          },
          "description": { "type": "string", "minLength": 1 },
          "requires_runtime": { "type": "boolean" },
          "runtime": {
            "type": ["string", "null"],
            "enum": ["docker", null]
          },
          "image": {
            "type": ["string", "null"]
          },
          "network": {
            "type": "string",
            "enum": ["host_default", "none"]
          },
          "workspace_mount": {
            "type": ["string", "null"]
          },
          "shell_interpolation": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "connector_adapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["adapter", "description", "resource_types", "auth_modes", "write_capable"],
        "properties": {
          "adapter": {
            "type": "string",
            "enum": ["ticket_reference", "docs_reference", "ci_status"]
          },
          "description": { "type": "string", "minLength": 1 },
          "resource_types": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "auth_modes": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "write_capable": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "starter_recipes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["recipe_id", "title", "policy_id", "scope", "budget"],
        "properties": {
          "recipe_id": { "type": "string" },
          "title": { "type": "string" },
          "policy_id": { "type": "string" },
          "scope": {
            "type": "object",
            "required": ["org_id", "project_id"],
            "properties": {
              "org_id": { "type": "string" },
              "project_id": { "type": "string" }
            },
            "additionalProperties": false
          },
          "budget": {
            "type": "object",
            "required": ["soft_limit_usd", "hard_limit_usd"],
            "properties": {
              "soft_limit_usd": { "type": "number", "minimum": 0 },
              "hard_limit_usd": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
