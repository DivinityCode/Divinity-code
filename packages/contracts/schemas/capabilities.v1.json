{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapabilitiesCatalog",
  "type": "object",
  "required": ["format", "generated_at", "policies", "execution_adapters", "runner_isolation_profiles", "connector_adapters", "starter_recipes"],
  "properties": {
    "format": { "const": "divinity.capabilities.v1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["policy_id", "permissions", "approval_threshold"],
        "properties": {
          "policy_id": { "type": "string" },
          "permissions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "approval_threshold": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          }
        },
        "additionalProperties": false
      }
    },
    "execution_adapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["adapter", "description", "action_types", "shell_interpolation"],
        "properties": {
          "adapter": {
            "type": "string",
            "enum": ["file_read", "git_status", "node_test", "package_script", "manual"]
          },
          "description": { "type": "string", "minLength": 1 },
          "action_types": {
            "type": "array",
            "items": { "type": "string" }
          },
          "shell_interpolation": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "runner_isolation_profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["profile_id", "kind", "description", "requires_runtime", "runtime", "image", "network", "workspace_mount", "shell_interpolation"],
        "properties": {
          "profile_id": {
            "type": "string",
            "enum": ["workspace_snapshot", "container_sandbox"]
          },
          "kind": {
            "type": "string",
            "enum": ["workspace", "container"]
          },
          "description": { "type": "string", "minLength": 1 },
          "requires_runtime": { "type": "boolean" },
          "runtime": {
            "type": ["string", "null"],
            "enum": ["docker", null]
          },
          "image": {
            "type": ["string", "null"]
          },
          "network": {
            "type": "string",
            "enum": ["host_default", "none"]
          },
          "workspace_mount": {
            "type": ["string", "null"]
          },
          "shell_interpolation": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "connector_adapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["adapter", "description", "resource_types", "auth_modes", "write_capable"],
        "properties": {
          "adapter": {
            "type": "string",
            "enum": ["ticket_reference", "docs_reference", "ci_status"]
          },
          "description": { "type": "string", "minLength": 1 },
          "resource_types": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "auth_modes": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "write_capable": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "starter_recipes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["recipe_id", "title", "policy_id", "scope", "budget"],
        "properties": {
          "recipe_id": { "type": "string" },
          "title": { "type": "string" },
          "policy_id": { "type": "string" },
          "scope": {
            "type": "object",
            "required": ["org_id", "project_id"],
            "properties": {
              "org_id": { "type": "string" },
              "project_id": { "type": "string" }
            },
            "additionalProperties": false
          },
          "budget": {
            "type": "object",
            "required": ["soft_limit_usd", "hard_limit_usd"],
            "properties": {
              "soft_limit_usd": { "type": "number", "minimum": 0 },
              "hard_limit_usd": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
