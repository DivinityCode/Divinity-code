{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Run",
  "type": "object",
  "required": ["run_id", "task_id", "status", "risk_level"],
  "properties": {
    "run_id": { "type": "string" },
    "task_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "awaiting_approval", "paused", "completed", "failed"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "goals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["goal_id", "run_id", "task_id", "status", "source", "title"],
        "properties": {
          "goal_id": { "type": "string" },
          "run_id": { "type": "string" },
          "task_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "blocked", "completed"]
          },
          "source": {
            "type": "string",
            "enum": ["task.success_criteria"]
          },
          "title": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "approval_comments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["comment_id", "run_id", "actor", "body", "created_at"],
        "properties": {
          "comment_id": { "type": "string" },
          "run_id": { "type": "string" },
          "actor": { "type": "string", "minLength": 1 },
          "body": { "type": "string", "minLength": 1 },
          "created_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "approval_revision": {
      "type": "object",
      "required": ["revision_id", "run_id", "actor", "reason", "requested_changes", "status", "requested_at"],
      "properties": {
        "revision_id": { "type": "string" },
        "run_id": { "type": "string" },
        "actor": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "requested_changes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "status": {
          "type": "string",
          "enum": ["requested", "resubmitted"]
        },
        "requested_at": { "type": "string", "format": "date-time" },
        "resubmitted_by": { "type": "string", "minLength": 1 },
        "resubmission_reason": { "type": "string" },
        "resubmitted_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
