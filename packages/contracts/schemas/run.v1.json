{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Run",
  "type": "object",
  "required": ["run_id", "task_id", "status", "risk_level"],
  "properties": {
    "run_id": { "type": "string" },
    "task_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "awaiting_approval", "paused", "completed", "failed"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "goals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["goal_id", "run_id", "task_id", "status", "source", "title"],
        "properties": {
          "goal_id": { "type": "string" },
          "run_id": { "type": "string" },
          "task_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "blocked", "completed"]
          },
          "source": {
            "type": "string",
            "enum": ["task.success_criteria"]
          },
          "title": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "approval_comments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["comment_id", "run_id", "actor", "body", "created_at"],
        "properties": {
          "comment_id": { "type": "string" },
          "run_id": { "type": "string" },
          "actor": { "type": "string", "minLength": 1 },
          "body": { "type": "string", "minLength": 1 },
          "created_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "approval_revision": {
      "type": "object",
      "required": ["revision_id", "run_id", "actor", "reason", "requested_changes", "status", "requested_at"],
      "properties": {
        "revision_id": { "type": "string" },
        "run_id": { "type": "string" },
        "actor": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "requested_changes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "status": {
          "type": "string",
          "enum": ["requested", "resubmitted"]
        },
        "requested_at": { "type": "string", "format": "date-time" },
        "resubmitted_by": { "type": "string", "minLength": 1 },
        "resubmission_reason": { "type": "string" },
        "resubmitted_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "provider_tool_call_approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "format",
          "approval_id",
          "run_id",
          "tool_call_id",
          "provider_id",
          "transport",
          "name",
          "argument_keys",
          "arguments_redacted",
          "decision",
          "actor",
          "reason",
          "decided_at"
        ],
        "properties": {
          "format": { "const": "divinity.provider_tool_call_approval.v1" },
          "approval_id": { "type": "string", "minLength": 1 },
          "run_id": { "type": "string", "minLength": 1 },
          "tool_call_id": { "type": "string", "minLength": 1 },
          "provider_id": { "type": "string", "minLength": 1 },
          "transport": {
            "type": "string",
            "enum": ["chat_completions", "anthropic_messages", "codex_responses"]
          },
          "name": { "type": "string", "minLength": 1 },
          "argument_keys": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "arguments_redacted": { "const": true },
          "decision": {
            "type": "string",
            "enum": ["approve", "reject"]
          },
          "actor": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "decided_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "provider_tool_executions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "format",
          "execution_id",
          "run_id",
          "approval_id",
          "tool_call_id",
          "provider_id",
          "transport",
          "name",
          "argument_keys",
          "arguments_redacted",
          "status",
          "adapter",
          "actor",
          "reason",
          "started_at",
          "completed_at",
          "output_summary",
          "output_redacted",
          "output_metadata"
        ],
        "properties": {
          "format": { "const": "divinity.provider_tool_execution.v1" },
          "execution_id": { "type": "string", "minLength": 1 },
          "run_id": { "type": "string", "minLength": 1 },
          "approval_id": { "type": "string", "minLength": 1 },
          "tool_call_id": { "type": "string", "minLength": 1 },
          "provider_id": { "type": "string", "minLength": 1 },
          "transport": {
            "type": "string",
            "enum": ["chat_completions", "anthropic_messages", "codex_responses"]
          },
          "name": { "type": "string", "minLength": 1 },
          "argument_keys": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "arguments_redacted": { "const": true },
          "status": {
            "type": "string",
            "enum": ["completed", "failed", "blocked"]
          },
          "adapter": {
            "type": "string",
            "enum": ["read_file", "search_files", "unsupported"]
          },
          "actor": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "started_at": { "type": "string", "format": "date-time" },
          "completed_at": { "type": "string", "format": "date-time" },
          "output_summary": { "type": "string" },
          "output_redacted": { "const": true },
          "output_metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "operator_summary": { "type": "string", "minLength": 1 },
          "operator_summary_source": {
            "type": "string",
            "const": "operator"
          },
          "error": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
