{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GoalRecord",
  "type": "object",
  "required": [
    "goal_id",
    "run_id",
    "task_id",
    "scope",
    "source",
    "title",
    "status",
    "budget_estimate_usd",
    "evidence_refs",
    "completion_evidence_refs",
    "created_at"
  ],
  "properties": {
    "goal_id": { "type": "string" },
    "run_id": { "type": "string" },
    "task_id": { "type": "string" },
    "scope": {
      "type": "object",
      "required": ["org_id", "project_id"],
      "properties": {
        "org_id": { "type": "string" },
        "project_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "string",
      "enum": ["task.success_criteria"]
    },
    "title": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["pending", "blocked", "completed"]
    },
    "budget_estimate_usd": { "type": "number", "minimum": 0 },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "completion_evidence_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "$defs": {
    "evidence_ref": {
      "type": "object",
      "required": ["evidence_id", "source", "claim_type", "summary", "supports"],
      "properties": {
        "evidence_id": { "type": "string" },
        "source": { "type": "string" },
        "claim_type": {
          "type": "string",
          "enum": ["observed", "inferred"]
        },
        "summary": { "type": "string" },
        "supports": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
