{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExecutionLockRecord",
  "type": "object",
  "required": ["lock_id", "run_id", "step_id", "actor", "status", "locked_at", "expires_at", "released_at"],
  "properties": {
    "lock_id": { "type": "string" },
    "run_id": { "type": "string" },
    "step_id": { "type": "string" },
    "actor": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["locked", "released", "failed", "stale"]
    },
    "locked_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "released_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false
}
