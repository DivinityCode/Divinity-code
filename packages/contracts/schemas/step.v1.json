{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Step",
  "type": "object",
  "required": ["step_id", "run_id", "action", "status", "pre_execution_check"],
  "properties": {
    "step_id": { "type": "string" },
    "run_id": { "type": "string" },
    "action": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "completed", "failed", "blocked"]
    },
    "execution": {
      "type": "object",
      "required": [
        "execution_id",
        "run_id",
        "step_id",
        "adapter",
        "status",
        "exit_code",
        "attempt",
        "max_attempts",
        "retry_of",
        "target_path",
        "stdout",
        "stderr",
        "started_at",
        "completed_at"
      ],
      "properties": {
        "execution_id": { "type": "string" },
        "run_id": { "type": "string" },
        "step_id": { "type": "string" },
        "adapter": {
          "type": "string",
          "enum": ["file_read", "git_status", "node_test", "package_script", "manual"]
        },
        "status": {
          "type": "string",
          "enum": ["completed", "failed"]
        },
        "exit_code": { "type": "integer" },
        "attempt": { "type": "integer", "minimum": 1 },
        "max_attempts": { "type": "integer", "minimum": 1 },
        "retry_of": { "type": ["string", "null"] },
        "target_path": { "type": ["string", "null"] },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "required": [
        "verification_id",
        "run_id",
        "step_id",
        "execution_id",
        "status",
        "result",
        "checks",
        "evidence_refs",
        "started_at",
        "completed_at"
      ],
      "properties": {
        "verification_id": { "type": "string" },
        "run_id": { "type": "string" },
        "step_id": { "type": "string" },
        "execution_id": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["completed"]
        },
        "result": {
          "type": "string",
          "enum": ["passed", "failed"]
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["check_id", "status", "summary"],
            "properties": {
              "check_id": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["passed", "failed"]
              },
              "summary": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["evidence_id", "source", "claim_type", "summary", "supports"],
            "properties": {
              "evidence_id": { "type": "string" },
              "source": { "type": "string" },
              "claim_type": {
                "type": "string",
                "enum": ["observed", "inferred"]
              },
              "summary": { "type": "string" },
              "supports": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "pre_execution_check": {
      "type": "object",
      "required": ["decision", "status", "risk_level", "approval_required", "blocked_reasons", "evidence_refs"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["allow", "requires_approval", "block"]
        },
        "status": {
          "type": "string",
          "enum": ["allowed", "blocked"]
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "approval_required": { "type": "boolean" },
        "blocked_reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["evidence_id", "source", "claim_type", "summary", "supports"],
            "properties": {
              "evidence_id": { "type": "string" },
              "source": { "type": "string" },
              "claim_type": {
                "type": "string",
                "enum": ["observed", "inferred"]
              },
              "summary": { "type": "string" },
              "supports": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
